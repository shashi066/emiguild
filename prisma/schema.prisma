// Local dev schema — SQLite
// Production uses prisma/schema.production.prisma (PostgreSQL/Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings          Booking[]
  passes            UserPass[]
  dailySpins        UserDailySpin[]
  drawEntries       DrawEntry[]
  wonDraws          LuckyDraw[] @relation("DrawWinner")
  tournamentPlayers TournamentPlayer[]
  armoryInventory   ArmoryInventory[]
  armoryLoadout     ArmoryLoadout?
  armoryDailyClaims ArmoryDailyClaim[]
  armoryTickets     ArmoryTicket[]

  @@map("users")
}

model Station {
  id              String   @id @default(cuid())
  name            String
  description     String
  specs           String
  hourlyRate      Float
  minDuration     Float    @default(1)
  hasControllers  Boolean  @default(true)
  imageUrl        String?
  isActive        Boolean  @default(true)
  position        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[]

  @@map("stations")
}

model Booking {
  id                String   @id @default(cuid())
  userId            String?
  stationId         String
  date              String
  startTime         String
  endTime           String
  duration          Float
  totalPrice        Float
  status            String   @default("PENDING")
  bookingType       String   @default("ONLINE")
  customerName      String?
  customerPhone     String?
  paymentStatus     String   @default("UNPAID")
  razorpayOrderId   String?
  razorpayPaymentId String?
  extraControllers  Int      @default(0)
  controllerCharge  Float    @default(0)
  discount          Int      @default(0)
  notes             String?
  adminComment      String?
  userPassId        String?
  passHoursDeducted Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User?     @relation(fields: [userId],     references: [id], onDelete: SetNull)
  station  Station   @relation(fields: [stationId],  references: [id], onDelete: Cascade)
  userPass UserPass? @relation(fields: [userPassId], references: [id], onDelete: SetNull)

  @@map("bookings")
}

model UserPass {
  id          String   @id @default(cuid())
  userId      String
  passType    String
  totalHours  Int
  usedHours   Float    @default(0)
  price       Int
  status      String   @default("ACTIVE")
  purchasedAt DateTime @default(now())
  expiresAt   DateTime

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("user_passes")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String?
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model LootItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  iconUrl     String?
  weight      Int
  enabled     Boolean  @default(true)
  rarity      String?  @default("COMMON")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  spins UserDailySpin[]

  @@map("loot_items")
}

model UserDailySpin {
  id         String   @id @default(cuid())
  userId     String
  lootItemId String?
  spinDate   String   // YYYY-MM-DD in IST
  attempts   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId],     references: [id], onDelete: Cascade)
  lootItem LootItem? @relation(fields: [lootItemId], references: [id], onDelete: SetNull)

  @@unique([userId, spinDate])
  @@map("user_daily_spins")
}

model LuckyDraw {
  id             String    @id @default(cuid())
  title          String
  description    String?
  prize          String
  status         String    @default("DRAFT")
  startsAt       DateTime?
  endsAt         DateTime?
  winnerId       String?
  winnerPickedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  entries DrawEntry[]
  winner  User?       @relation("DrawWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@map("lucky_draws")
}

model DrawEntry {
  id        String   @id @default(cuid())
  drawId    String
  userId    String
  createdAt DateTime @default(now())

  draw LuckyDraw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([drawId, userId])
  @@map("draw_entries")
}

model Game {
  id        String   @id @default(cuid())
  name      String
  category  String
  isActive  Boolean  @default(true)
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("games")
}

model Tournament {
  id           String   @id @default(cuid())
  name         String
  game         String   @default("FC26")
  date         String   // YYYY-MM-DD
  entryFee     String   @default("Free")
  prizePool    String   @default("")
  maxPlayers   Int      @default(16)
  status       String   @default("REGISTRATION_OPEN") // REGISTRATION_OPEN | REGISTRATION_CLOSED | ONGOING | FINISHED
  bracketGenerated Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  players TournamentPlayer[]
  matches TournamentMatch[]

  @@map("tournaments")
}

model TournamentPlayer {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String?  // linked to an app user if they self-registered
  name         String
  phone        String?
  seed         Int      @default(0) // display order / seeding
  createdAt    DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  matchesAsP1 TournamentMatch[] @relation("MatchPlayer1")
  matchesAsP2 TournamentMatch[] @relation("MatchPlayer2")
  matchesWon  TournamentMatch[] @relation("MatchWinner")

  @@map("tournament_players")
}

model TournamentMatch {
  id           String   @id @default(cuid())
  tournamentId String
  round        Int      // 1 = first round, 2 = second, etc.
  matchIndex   Int      // position within the round (0-indexed)
  player1Id    String?
  player2Id    String?
  score1       Int      @default(0)
  score2       Int      @default(0)
  winnerId     String?
  status       String   @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED
  isBye        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player1    TournamentPlayer? @relation("MatchPlayer1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2    TournamentPlayer? @relation("MatchPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner     TournamentPlayer? @relation("MatchWinner",  fields: [winnerId],  references: [id], onDelete: SetNull)

  @@map("tournament_matches")
}

model ArmorySet {
  id             String   @id
  name           String
  shortLabel     String
  rarity         String
  dropPercentage Int      @default(0)
  active         Boolean  @default(true)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  artifacts ArmoryArtifact[]
  rewards   ArmorySetReward[]
  tickets   ArmoryTicket[]

  @@map("armory_sets")
}

model ArmoryArtifact {
  id                 String   @id
  setId              String
  slotType           String
  name               String
  active             Boolean  @default(true)
  slotDropPercentage Int      @default(25)
  displayOrder       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  set             ArmorySet          @relation(fields: [setId], references: [id], onDelete: Cascade)
  inventory       ArmoryInventory[]
  dailyClaims     ArmoryDailyClaim[]
  headgearLoadout ArmoryLoadout[]    @relation("ArmoryHeadgear")
  armorLoadout    ArmoryLoadout[]    @relation("ArmoryArmor")
  glovesLoadout   ArmoryLoadout[]    @relation("ArmoryGloves")
  bootsLoadout    ArmoryLoadout[]    @relation("ArmoryBoots")

  @@unique([setId, slotType])
  @@map("armory_artifacts")
}

model ArmoryInventory {
  id         String   @id @default(cuid())
  userId     String
  artifactId String
  quantity   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifact ArmoryArtifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([userId, artifactId])
  @@map("armory_inventory")
}

model ArmoryLoadout {
  id                 String   @id @default(cuid())
  userId             String   @unique
  headgearArtifactId String?
  armorArtifactId    String?
  glovesArtifactId   String?
  bootsArtifactId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  headgear ArmoryArtifact?  @relation("ArmoryHeadgear", fields: [headgearArtifactId], references: [id], onDelete: SetNull)
  armor    ArmoryArtifact?  @relation("ArmoryArmor", fields: [armorArtifactId], references: [id], onDelete: SetNull)
  gloves   ArmoryArtifact?  @relation("ArmoryGloves", fields: [glovesArtifactId], references: [id], onDelete: SetNull)
  boots    ArmoryArtifact?  @relation("ArmoryBoots", fields: [bootsArtifactId], references: [id], onDelete: SetNull)

  @@map("armory_loadouts")
}

model ArmoryDailyClaim {
  id         String   @id @default(cuid())
  userId     String
  claimDate  String
  artifactId String
  createdAt  DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifact ArmoryArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([userId, claimDate])
  @@map("armory_daily_claims")
}

model ArmorySetReward {
  id                  String   @id @default(cuid())
  setId               String   @unique
  rewardType          String
  discountPercentage  Int?
  discountAmount      Int?
  gamingMinutes       Int?
  racingMinutes       Int?
  validityDays        Int      @default(7)
  minimumBookingValue Int?
  eligibleStations    String?
  weekdayOnly         Boolean  @default(false)
  maximumDiscount     Int?
  active              Boolean  @default(true)
  description         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  set ArmorySet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@map("armory_set_rewards")
}

model ArmoryTicket {
  id             String    @id @default(cuid())
  userId         String
  setId          String
  rewardSnapshot String
  code           String    @unique
  status         String    @default("UNUSED")
  claimedAt      DateTime  @default(now())
  expiresAt      DateTime
  redeemedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  set  ArmorySet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@map("armory_tickets")
}
